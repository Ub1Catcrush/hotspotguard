<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:minHeight="600dp">

        <!-- Shield Icon (konsistent mit Dashboard) -->
        <ImageView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@drawable/ic_shield"
            android:layout_marginBottom="16dp"
            app:tint="@color/primary_light" />

        <!-- Title -->
        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="@color/on_surface"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <!-- Subtitle -->
        <TextView
            android:id="@+id/tv_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/subtitle_verify"
            android:textColor="@color/on_surface_variant"
            android:textSize="15sp"
            android:layout_marginBottom="32dp" />

        <!-- Status Card (nur bei Verify-Modus) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/surface_variant"
            app:cardCornerRadius="12dp"
            android:layout_marginBottom="24dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_shield"
                    android:layout_marginEnd="12dp"
                    app:tint="@color/status_active" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_service_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/service_active"
                        android:textColor="@color/status_active"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_hotspot_blocked"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_blocked_attempts"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Password Input -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Passwort"
            app:boxBackgroundColor="@color/surface_variant"
            app:boxStrokeColor="@color/primary_light"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_password"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPassword"
                android:textColor="@color/on_surface"
                android:imeOptions="actionDone" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Confirm Password Input -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_confirm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Passwort bestätigen"
            app:boxBackgroundColor="@color/surface_variant"
            app:boxStrokeColor="@color/primary_light"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="8dp"
            android:visibility="gone">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_password_confirm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPassword"
                android:textColor="@color/on_surface"
                android:imeOptions="actionDone" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Error Text -->
        <TextView
            android:id="@+id/tv_error"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/status_inactive"
            android:textSize="13sp"
            android:layout_marginBottom="12dp"
            android:visibility="gone" />

        <!-- Confirm Button mit Shield-Icon -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_confirm"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/btn_unlock"
            android:textSize="16sp"
            android:textStyle="bold"
            app:icon="@drawable/ic_shield"
            app:iconGravity="textStart"
            app:backgroundTint="@color/primary_light"
            app:cornerRadius="12dp" />

        <!-- Reset-Button (nur im Verify-Modus sichtbar) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_reset_app"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="@string/btn_reset_app"
            android:textSize="13sp"
            android:layout_marginTop="12dp"
            app:backgroundTint="@color/surface_variant"
            app:strokeColor="@color/status_inactive"
            app:strokeWidth="1dp"
            android:textColor="@color/status_inactive"
            app:cornerRadius="12dp"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
